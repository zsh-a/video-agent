{
  "name": "video-agent",
  "description": "A new CLI generated with oclif",
  "version": "0.0.0",
  "packageManager": "bun@1.3.14",
  "author": "zsh",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "vagent": "./bin/run.js"
  },
  "bugs": "https://github.com/zs/video-agent/issues",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@video-agent/api": "workspace:*",
    "@video-agent/core": "workspace:*",
    "@video-agent/db": "workspace:*",
    "@video-agent/ir": "workspace:*",
    "@video-agent/llm": "workspace:*",
    "@video-agent/mcp": "workspace:*",
    "@video-agent/media": "workspace:*",
    "@video-agent/providers": "workspace:*",
    "@video-agent/quality": "workspace:*",
    "@video-agent/renderer-ffmpeg": "workspace:*",
    "@video-agent/renderer-hyperframes": "workspace:*",
    "@video-agent/runtime": "workspace:*",
    "ai": "^5.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/zs/video-agent",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "vagent",
    "dirname": "vagent",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " "
  },
  "repository": "zs/video-agent",
  "scripts": {
    "build": "bun run clean && tsc -b",
    "clean": "shx rm -rf dist tsconfig.tsbuildinfo packages/*/dist packages/*/*.tsbuildinfo",
    "dev": "bun ./bin/dev.js",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "bun run lint",
    "prepack": "oclif manifest && oclif readme",
    "start": "bun ./bin/dev.js",
    "test": "bun run build && mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
