{
  "name": "video-agent",
  "description": "Bun-first TypeScript video agent framework",
  "version": "0.0.0",
  "packageManager": "bun@1.3.14",
  "author": "zsh",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "vagent": "./bin/run.js"
  },
  "bugs": "https://github.com/zs/video-agent/issues",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@clack/prompts": "^1.5.1",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@video-agent/api": "workspace:*",
    "@video-agent/core": "workspace:*",
    "@video-agent/db": "workspace:*",
    "@video-agent/ir": "workspace:*",
    "@video-agent/llm": "workspace:*",
    "@video-agent/mcp": "workspace:*",
    "@video-agent/media": "workspace:*",
    "@video-agent/providers": "workspace:*",
    "@video-agent/quality": "workspace:*",
    "@video-agent/renderer-ffmpeg": "workspace:*",
    "@video-agent/renderer-hyperframes": "workspace:*",
    "@video-agent/runtime": "workspace:*",
    "ai": "^6.0.205",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^18",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "oclif": "^4",
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/zs/video-agent",
  "imports": {
    "#test/expect": "./test/support/expect.ts"
  },
  "keywords": [
    "agent",
    "bun",
    "ffmpeg",
    "video"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "vagent",
    "dirname": "vagent",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " "
  },
  "repository": "zs/video-agent",
  "scripts": {
    "build": "bun run clean && tsc -b",
    "clean": "bun ./scripts/clean.js",
    "dev": "bun ./bin/dev.js",
    "lint": "eslint",
    "postpack": "bun ./scripts/postpack-clean.js",
    "posttest": "bun run lint",
    "prepack": "oclif manifest && oclif readme",
    "start": "bun ./bin/dev.js",
    "test": "bun run build && bun test --timeout 60000 ./test",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
