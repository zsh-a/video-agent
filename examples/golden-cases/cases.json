        "forbid": ["Image:", "README-", "贡献者列表"],
        "qualityMustPass": true
      }
    },
    {
      "id": "md-ossf-scorecard-checks",
      "title": "OpenSSF Scorecard checks excerpt",
      "pipeline": "deck",
      "mode": "script-generated",
      "language": "en-US",
