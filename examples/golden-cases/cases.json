{
  "version": 1,
  "description": "First Deck Explainer golden cases. Keep source media out of git; materialize fixtures locally before running provider-backed evaluations.",
  "cases": [
    {
      "id": "md-k8s-pods-en",
      "title": "Kubernetes Pods concept page",
      "pipeline": "deck",
      "mode": "script-generated",
      "language": "en-US",
      "input": {
        "kind": "markdown",
        "path": "fixtures/md-k8s-pods-en/input.md"
      },
      "source": {
        "name": "Kubernetes website documentation",
        "homepage": "https://github.com/kubernetes/website",
        "downloadUrl": "https://raw.githubusercontent.com/kubernetes/website/main/content/en/docs/concepts/workloads/pods/_index.md",
        "license": "CC-BY-4.0",
        "licenseUrl": "https://github.com/kubernetes/website/blob/main/LICENSE"
      },
      "run": {
        "command": "bun run dev deck examples/golden-cases/fixtures/md-k8s-pods-en/input.md --duration 3m --language en-US --project-id golden-md-k8s-pods-en"
      },
      "expected": {
        "minSlides": 6,
        "maxSlides": 12,
        "requiredSlideTypes": ["hero", "process", "code", "summary"],
        "mustMention": ["Pod", "containers", "network", "storage"],
        "forbid": ["{{<", "{{%", "frontmatter"],
        "qualityMustPass": true
      }
    },
    {
