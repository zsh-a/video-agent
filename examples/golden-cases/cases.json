    {
      "id": "md-turing-way-cn",
      "title": "The Turing Way Chinese README excerpt",
      "pipeline": "deck",
      "mode": "script-generated",
      "language": "zh-CN",
      "input": {
        "kind": "markdown",
        "path": "fixtures/md-turing-way-cn/input.md"
