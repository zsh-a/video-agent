      "run": {
        "command": "bun run dev deck examples/golden-cases/fixtures/md-ossf-scorecard-checks/input.md --duration 150s --language en-US --project-id golden-md-ossf-scorecard-checks"
      },
      "expected": {
        "minSlides": 5,
        "maxSlides": 9,
        "requiredSlideTypes": ["hero", "comparison", "process", "summary"],
        "mustMention": ["risk", "remediation", "workflow", "license"],
        "forbid": ["full checklist dump"],
        "qualityMustPass": true
      }
    },
